# Backend API base URL (server-side only, e.g. https://api.example.com)
BACKEND_URL=

# Backend API base URL exposed to the client (used by app/api/privacy-policy)
NEXT_PUBLIC_BACKEND_URL=

# Fixed shipping cost shown at checkout for carts under $70.000 (free above that threshold)
NEXT_PUBLIC_FIXED_SHIPPING_COST=5990

# Base URL of the S3 bucket/prefix that serves site assets (logo, etc.)
# e.g. https://mi-bucket.s3.<region>.amazonaws.com/socomarca-qa  (no trailing slash)
# Asset paths are appended in code: `${base}/assets/logo.png` (logo),
# `${base}/assets/icons/logo.ico` (favicon), `${base}/assets/default.png` (imagen por defecto / fallback).
# If empty, local fallbacks under /public are used.
NEXT_PUBLIC_S3_BASE_URL=

# When "true", skips the auth middleware entirely (QA/testing only)
QA_MODE=false

# Static JWT used when QA_MODE is enabled
QA_JWT=

# Port for the custom server (used by `pnpm dev:large-files`)
PORT=3000
